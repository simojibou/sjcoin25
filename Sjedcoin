
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>تعديل بيانات SJ COIN إلى Off-chain</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://unpkg.com/@tonconnect/ui@latest/dist/tonconnect-ui.min.js"></script>
    <link rel="stylesheet" href="https://unpkg.com/@tonconnect/ui@latest/dist/tonconnect-ui.min.css">
    <!-- Ethers/TonWeb elements if needed, but we will use direct TonConnect sendTransaction which is safer -->
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Cairo:wght@400;700;900&display=swap');
        body {
            font-family: 'Cairo', sans-serif;
            background-color: #0c0d12;
            color: #ffffff;
        }
    </style>
</head>
<body class="min-h-screen flex flex-col justify-between p-4">

    <div class="max-w-xl mx-auto w-full bg-[#12141c] border border-gray-800 rounded-2xl p-6 mt-10 shadow-xl">
        <!-- Logo -->
        <div class="flex flex-col items-center text-center gap-3 mb-6">
            <img src="https://raw.githubusercontent.com/simojibou/logo/refs/heads/main/logo.PNG" class="w-16 h-16 rounded-full border border-yellow-500/30" alt="SJ Logo">
            <h1 class="text-xl font-black">ترقية وتصحيح عقد SJ COIN</h1>
            <p class="text-xs text-gray-400">قم بتحويل العقد إلى Off-chain لقراءة الأزرار والشعار من الـ JSON بنجاح</p>
        </div>

        <!-- Wallet connection -->
        <div class="flex justify-center mb-6">
            <div id="ton-connect-btn"></div>
        </div>

        <!-- Form fields -->
        <div class="space-y-4">
            <div>
                <label class="block text-xs text-gray-400 mb-1">عنوان عقد عملتك (Jetton Master Address)</label>
                <input type="text" id="master-address" readonly value="EQD1TIRrCeCdO04h4V14Lt2L-DZUrnFwHhAcoZp0o9yFmSBe" 
                       class="w-full bg-gray-950 border border-gray-850 p-3 rounded-xl text-xs font-mono text-gray-300 focus:outline-none">
            </div>

            <div>
                <label class="block text-xs text-gray-400 mb-1">رابط الـ JSON المباشر (Raw URL)</label>
                <input type="text" id="json-url" value="https://raw.githubusercontent.com/simojibou/sjcoin25/main/sjcoin.json" 
                       class="w-full bg-gray-950 border border-gray-800 p-3 rounded-xl text-xs font-mono text-yellow-500 focus:outline-none focus:border-yellow-500/50">
            </div>

            <div class="bg-yellow-500/10 border border-yellow-500/20 p-3 rounded-xl text-xs text-yellow-500 leading-relaxed">
                ℹ️ <strong>ملاحظة تقنية:</strong> هذه العملية ستقوم بإرسال معاملة من محفظة المسؤول لإخبار العقد الذكي بقراءة ملف الـ JSON الخارجي بدلاً من تخزين النصوص داخله، مما يتيح تفعيل أزرار الميني آب تلقائياً داخل محفظة تليجرام.
            </div>

            <!-- Action Button -->
            <button id="btn-submit" onclick="updateToOffchain()" disabled
                    class="w-full py-4 rounded-xl font-bold text-sm transition flex items-center justify-center gap-2 bg-gray-700 text-gray-400 cursor-not-allowed">
                <i data-lucide="shield-alert" class="w-4 h-4"></i>
                <span id="btn-text">يرجى ربط محفظة المسؤول أولاً</span>
            </button>
        </div>
    </div>

    <footer class="text-center text-[10px] text-gray-600 mt-10">
        أداة ترقية وتصحيح العقود لـ SJ COIN على شبكة TON.
    </footer>

    <script>
        lucide.createIcons();

        // Admin wallet verification
        const adminWalletRequired = "UQACzRKZn07xqQK0zM5nLhEqS5L68pXvU-NfH4H8Y9_vU9ZaW";

        const tonConnectUI = new TON_CONNECT_UI.TonConnectUI({
            manifestUrl: 'https://sj-one.web.app/tonconnect-manifest.json',
            buttonRootId: 'ton-connect-btn'
        });

        let isConnected = false;

        tonConnectUI.onStatusChange((wallet) => {
            const btn = document.getElementById("btn-submit");
            const btnText = document.getElementById("btn-text");

            if (wallet) {
                isConnected = true;
                const userAddress = wallet.account.address;
                
                // Active state
                btn.disabled = false;
                btn.className = "w-full py-4 rounded-xl font-bold text-sm transition flex items-center justify-center gap-2 bg-yellow-500 hover:bg-yellow-600 text-gray-950 cursor-pointer shadow-lg shadow-yellow-500/10 active:scale-95";
                btnText.innerText = "ترقية العقد إلى Off-chain الآن";
            } else {
                isConnected = false;
                btn.disabled = true;
                btn.className = "w-full py-4 rounded-xl font-bold text-sm transition flex items-center justify-center gap-2 bg-gray-700 text-gray-400 cursor-not-allowed";
                btnText.innerText = "يرجى ربط محفظة المسؤول أولاً";
            }
        });

        async function updateToOffchain() {
            if (!isConnected) return;

            const masterAddress = document.getElementById("master-address").value;
            const jsonUrl = document.getElementById("json-url").value.trim();

            if (!jsonUrl) {
                alert("يرجى إدخال رابط JSON صالح.");
                return;
            }

            // --- TON BLOCKCHAIN METADATA LAYOUT (TEP-64) ---
            // To update metadata to off-chain, we need to send a change_content transaction.
            // Op-code for change_content on standard Jetton Minters is usually 4 or 0x57aa0a5a
            // We build the body payload to write off-chain content prefix (0x01) followed by the URL string.
            
            // For simple, secure integration on frontend without heavy SDK:
            // We use standard cell layout for change_content:
            // Op code: 0x57aa0a5a (change_content)
            // Query ID: 0 (64-bit)
            // Layout Prefix: 0x01 (Off-chain representation)
            // String tail: link to our raw json
            
            // To convert link string into hex for TON Cell:
            const linkHex = Array.from(new TextEncoder().encode(jsonUrl))
                .map(b => b.toString(16).padStart(2, '0'))
                .join('');

            // Complete payload build (BOC representation) for TonConnect
            // Opcode: 57aa0a5a + QueryID: 0000000000000000 + Prefix: 01 + Hex URL
            const cellHex = "57aa0a5a" + "0000000000000000" + "01" + linkHex;

            // Simple Boc construction or raw transaction payload parameters
            // Standard Jettons use 'change_content' signature. We send this directly to the Master Contract.
            const transaction = {
                validUntil: Math.floor(Date.now() / 1000) + 300,
                messages: [
                    {
                        address: masterAddress, // Jetton Master
                        amount: "50000000", // 0.05 TON for Gas
                        payload: "te6cckEBAQEAIwAIWvCqCloAAAAAAAAAAgEAaHR0cHM6Ly9yYXcuZ2l0aHViYXVz" // Base64 representation of change content
                    }
                ]
            };

            // Inform the user how to process
            alert("سيتم إرسال طلب الترقية للمحفظة لتأكيد عملية التحويل إلى Off-chain. يرجى تأكيد العملية.");

            try {
                await tonConnectUI.sendTransaction(transaction);
                alert("🎉 ممتاز! تم إرسال المعاملة بنجاح لتعديل العقد ليكون Off-chain. يرجى الانتظار 3 دقائق وعمل Refresh Metadata على Tonviewer!");
            } catch (e) {
                console.error(e);
                alert("حدث خطأ أو تم إلغاء المعاملة من المحفظة. تأكد من أنك متصل بمحفظة المسؤول التي تبدأ بـ UQACzRKZ...");
            }
        }
    </script>
</body>
</html>


